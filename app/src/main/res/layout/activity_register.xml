<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/celeste_suave"
    tools:context=".RegistrarActivity">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="57dp"
        android:background="@color/azul_oscuro"
        android:minHeight="?attr/actionBarSize"
        app:title="Nuevo usuario"
        app:titleTextColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Imagen -->
    <ImageView
        android:id="@+id/imageview_icono"
        android:layout_width="150dp"
        android:layout_height="110dp"
        android:layout_marginTop="48dp"
        android:src="@mipmap/registro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <!-- CardView para los campos -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_register"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:cardCornerRadius="40dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/celesteclaro"
        app:layout_constraintTop_toBottomOf="@id/imageview_icono"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Usuario -->
            <EditText
                android:id="@+id/edittext_usuario"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Usuario"
                android:inputType="text"
                android:padding="12dp"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:background="@drawable/bg_edittext_rounded" />

            <!-- Email -->
            <EditText
                android:id="@+id/edittext_email"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:hint="Correo electrónico"
                android:inputType="textEmailAddress"
                android:padding="12dp"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:background="@drawable/bg_edittext_rounded" />

            <!-- Contraseña -->
            <EditText
                android:id="@+id/edittext_password"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:hint="Contraseña"
                android:inputType="textPassword"
                android:padding="12dp"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:background="@drawable/bg_edittext_rounded" />

            <!-- Confirmar contraseña -->
            <EditText
                android:id="@+id/edittext_confirmar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:hint="Confirmar contraseña"
                android:inputType="textPassword"
                android:padding="12dp"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:background="@drawable/bg_edittext_rounded" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Botón Guardar -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_guardar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:text="Guardar"
        android:textColor="@color/white"
        android:backgroundTint="@color/verde_menta"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/card_register"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botón Regresar -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_regresar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:text="Regresar"
        android:textColor="@color/white"
        android:backgroundTint="@color/gris_texto"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/button_guardar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
