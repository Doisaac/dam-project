<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/frameLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/celeste_suave"
    tools:context=".ui.expediente.AddExpedienteFragment">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:fillViewport="true"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Título -->
            <TextView
                android:id="@+id/textview_titulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Crear Expediente"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/azul_oscuro"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

            <!-- Nombre -->
            <EditText
                android:id="@+id/editTextNombre"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Nombre"
                android:backgroundTint="@color/azul_claro"
                android:textColor="@color/gris_texto"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Apellido -->
            <EditText
                android:id="@+id/editTextApellido"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Apellido"
                android:backgroundTint="@color/azul_claro"
                android:textColor="@color/gris_texto"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Fecha nacimiento -->
            <EditText
                android:id="@+id/editTextFechaNacimiento"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Fecha de nacimiento"
                android:focusable="false"
                android:clickable="true"
                android:inputType="none"
                android:backgroundTint="@color/azul_claro"
                android:textColor="@color/gris_texto"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Género -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Género"
                android:textStyle="bold"
                android:textColor="@color/azul_oscuro"
                android:layout_marginBottom="4dp" />

            <RadioGroup
                android:id="@+id/radioGroupGenero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <RadioButton
                    android:id="@+id/radioMasculino"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Masculino"
                    android:textColor="@color/gris_texto"/>

                <RadioButton
                    android:id="@+id/radioFemenino"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Femenino"
                    android:textColor="@color/gris_texto"/>
            </RadioGroup>

            <!-- Teléfono -->
            <EditText
                android:id="@+id/editTextTelefono"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Teléfono"
                android:inputType="phone"
                android:backgroundTint="@color/azul_claro"
                android:textColor="@color/gris_texto"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Correo -->
            <EditText
                android:id="@+id/editTextCorreo"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Correo electrónico"
                android:inputType="textEmailAddress"
                android:backgroundTint="@color/azul_claro"
                android:textColor="@color/gris_texto"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Dirección -->
            <EditText
                android:id="@+id/editTextDireccion"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Dirección"
                android:backgroundTint="@color/azul_claro"
                android:textColor="@color/gris_texto"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Observaciones -->
            <EditText
                android:id="@+id/editTextObservaciones"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:hint="Observaciones"
                android:backgroundTint="@color/azul_claro"
                android:textColor="@color/gris_texto"
                android:padding="12dp"
                android:gravity="top"
                android:minLines="3"
                android:layout_marginBottom="16dp"/>

            <!-- Condiciones médicas-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Condiciones médicas:"
                android:textStyle="bold"
                android:textColor="@color/azul_oscuro"
                android:layout_marginBottom="8dp"/>

            <CheckBox android:id="@+id/checkboxDiabetes" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Diabetes"/>
            <CheckBox android:id="@+id/checkboxAnemia" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Anemia"/>
            <CheckBox android:id="@+id/checkboxGastritis" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gastritis"/>
            <CheckBox android:id="@+id/checkboxHTA" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hipertensión (HTA)"/>
            <CheckBox android:id="@+id/checkboxHemorragias" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hemorragias"/>
            <CheckBox android:id="@+id/checkboxAsma" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Asma"/>
            <CheckBox android:id="@+id/checkboxCardiacos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trastornos cardiacos"/>
            <CheckBox android:id="@+id/checkboxConvulsiones" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Convulsiones"/>
            <CheckBox android:id="@+id/checkboxTiroides" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tiroides"/>

            <!-- Botón Guardar -->
            <Button
                android:id="@+id/btnGuardarExpediente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guardar expediente"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/verde_menta"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp"/>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
