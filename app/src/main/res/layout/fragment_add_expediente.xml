<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/frameLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/celeste_suave"
    tools:context=".ui.expediente.AddExpedienteFragment">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:fillViewport="true"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Título -->
            <TextView
                android:id="@+id/textview_titulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Crear Expediente"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/azul_oscuro"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

            <!-- Card 0: Foto del paciente -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/celesteclaro"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imageExpediente"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_person_placeholder" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSeleccionarFoto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="@color/azul_oscuro"
                        android:fontFamily="sans-serif-medium"
                        android:text="Seleccionar Foto"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:cornerRadius="16dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 1: Nombre, Apellido, Fecha de nacimiento, genero -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/celesteclaro"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Datos personales"
                        android:textColor="@color/azul_oscuro"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginBottom="10dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nombre"
                        app:boxStrokeColor="@color/azul_claro"
                        app:boxBackgroundColor="@color/white"
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                        android:layout_marginBottom="10dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTextNombre"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/azul_oscuro"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Apellido"
                        app:boxStrokeColor="@color/azul_claro"
                        app:boxBackgroundColor="@color/white"
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                        android:layout_marginBottom="10dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTextApellido"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/azul_oscuro"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Fecha de nacimiento"
                        app:boxStrokeColor="@color/azul_claro"
                        app:boxBackgroundColor="@color/white"
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                        android:layout_marginBottom="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTextFechaNacimiento"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:clickable="true"
                            android:inputType="none"
                            android:textColor="@color/azul_oscuro"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Género"
                        android:textColor="@color/azul_oscuro"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginBottom="8dp"/>

                    <RadioGroup
                        android:id="@+id/radioGroupGenero"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioMasculino"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Masculino"
                            android:textColor="@color/azul_oscuro"/>

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioFemenino"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Femenino"
                            android:textColor="@color/azul_oscuro"/>
                    </RadioGroup>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 2: Teléfono, Correo -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/celesteclaro"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Contacto"
                        android:textColor="@color/azul_oscuro"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginBottom="10dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Teléfono"
                        app:boxStrokeColor="@color/azul_claro"
                        app:boxBackgroundColor="@color/white"
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                        android:layout_marginBottom="10dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTextTelefono"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"
                            android:textColor="@color/azul_oscuro"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Correo electrónico"
                        app:boxStrokeColor="@color/azul_claro"
                        app:boxBackgroundColor="@color/white"
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTextCorreo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/azul_oscuro"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 3: Dirección y Observaciones -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/celesteclaro"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Otros datos"
                        android:textColor="@color/azul_oscuro"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginBottom="10dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Dirección"
                        app:boxStrokeColor="@color/azul_claro"
                        app:boxBackgroundColor="@color/white"
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                        android:layout_marginBottom="10dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTextDireccion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/azul_oscuro"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Observaciones"
                        app:boxStrokeColor="@color/azul_claro"
                        app:boxBackgroundColor="@color/white"
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTextObservaciones"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top"
                            android:minLines="3"
                            android:textColor="@color/azul_oscuro"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 4: Género y Condiciones médicas -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/celesteclaro"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Condiciones médicas"
                        android:textColor="@color/azul_oscuro"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/checkboxDiabetes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Diabetes"
                        android:textColor="@color/gris_texto"/>
                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/checkboxAnemia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Anemia"
                        android:textColor="@color/gris_texto"/>
                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/checkboxGastritis"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gastritis"
                        android:textColor="@color/gris_texto"/>
                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/checkboxHTA"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hipertensión (HTA)"
                        android:textColor="@color/gris_texto"/>
                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/checkboxHemorragias"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hemorragias"
                        android:textColor="@color/gris_texto"/>
                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/checkboxAsma"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Asma"
                        android:textColor="@color/gris_texto"/>
                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/checkboxCardiacos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trastornos cardiacos"
                        android:textColor="@color/gris_texto"/>
                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/checkboxConvulsiones"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Convulsiones"
                        android:textColor="@color/gris_texto"/>
                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/checkboxTiroides"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tiroides"
                        android:textColor="@color/gris_texto"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botón Guardar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarExpediente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guardar expediente"
                android:textColor="@color/white"
                android:backgroundTint="@color/blue"
                app:cornerRadius="16dp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="32dp"/>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
